# Admin credentials for Mission Control
ADMIN_PASSWORD=change-me-to-a-strong-password
AUTH_SECRET=generate-a-random-32-char-string-here

# Phase 64.5.2 — Admin gate for /admin/error-messages editor.
# v1.9 single-operator. Migration path: replace with Supabase Auth session
# post-v1.9 (see T-64.5.2-05-02). Server-side ADMIN_EMAILS is the real check;
# NEXT_PUBLIC_ADMIN_EMAIL is the client-side identity passed via x-user-email
# header — both must match the operator's email.
ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAIL=

# Phase 64.5.2 — CLI humanization opt-in (read by packages/cli-connect runtime).
# Set CIRCOS_I18N=db to enable DB-backed humanized TTY output (text-mode only;
# JSON output unaffected). Lang detection priority: CIRCOS_LANG > LANG > LC_ALL > 'es'.
# CIRCOS_I18N=
# CIRCOS_LANG=

# OpenClaw paths (defaults shown - override if your setup differs)
# OPENCLAW_DIR=/root/.openclaw
# OPENCLAW_WORKSPACE=/root/.openclaw/workspace

# Branding (customize for your instance)
NEXT_PUBLIC_AGENT_NAME=Mission Control
NEXT_PUBLIC_AGENT_EMOJI=🤖
NEXT_PUBLIC_AGENT_DESCRIPTION=Your AI co-pilot, powered by OpenClaw
NEXT_PUBLIC_AGENT_LOCATION=
NEXT_PUBLIC_BIRTH_DATE=
NEXT_PUBLIC_AGENT_AVATAR=
NEXT_PUBLIC_OWNER_USERNAME=your-username
NEXT_PUBLIC_OWNER_EMAIL=your-email@example.com
NEXT_PUBLIC_OWNER_COLLAB_EMAIL=collabs@example.com
NEXT_PUBLIC_TWITTER_HANDLE=@username
NEXT_PUBLIC_COMPANY_NAME=MISSION CONTROL, INC.
NEXT_PUBLIC_APP_TITLE=Mission Control

# Smart Skill Intake (Phase 42 — v1.5.4)
# GitHub personal access token for server-side repo metadata fetch
# Scopes needed: public_repo (read-only)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# OpenAI API key for natural language skill detection (POST /api/skills/detect)
# Used only on Enter/explicit trigger — never on every keystroke
OPENAI_API_KEY=

# OpenAI OAuth (for single-session LLM classification without embedding raw API key)
# See: /api/auth/openai for OAuth flow
OPENAI_CLIENT_ID=your-openai-client-id
OPENAI_CLIENT_SECRET=your-openai-client-secret
OPENAI_REDIRECT_URI=http://localhost:3000/api/auth/openai/callback
